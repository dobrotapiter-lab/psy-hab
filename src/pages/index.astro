---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ForWhom from '../components/ForWhom.astro';
import Method from '../components/Method.astro';
import Reviews from '../components/Reviews.astro';
import Pricing from '../components/Pricing.astro';
import About from '../components/About.astro';
import Footer from '../components/Footer.astro';
---
&lt;BaseLayout 
  title="Евгений Полиенко — Психолог, коуч и проводник в мир самопознания"
  description="Путь к внутренней гармонии: психология, духовные практики и коучинг для тех, кто готов к трансформации."
&gt;
  &lt;main&gt;
    &lt;Hero /&gt;
    &lt;ForWhom /&gt;
    &lt;Method /&gt;
    &lt;Reviews /&gt;
    &lt;Pricing /&gt;
    &lt;About /&gt;
    &lt;Footer /&gt;
  &lt;/main&gt;
&lt;/BaseLayout&gt;
