---
import { Icon } from 'astro-icon/components';
---
&lt;section id="services" class="py-24 bg-bg-secondary relative overflow-hidden"&gt;
  &lt;div class="absolute top-20 right-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl"&gt;&lt;/div&gt;
  &lt;div class="absolute bottom-20 left-0 w-80 h-80 bg-secondary/5 rounded-full blur-3xl"&gt;&lt;/div&gt;
  &lt;div class="max-w-6xl mx-auto px-6 relative z-10"&gt;
    &lt;div class="text-center mb-16"&gt;&lt;h2 class="text-3xl md:text-4xl font-bold mb-4"&gt;Услуги и &lt;span class="gradient-text"&gt;стоимость&lt;/span&gt;&lt;/h2&gt;&lt;p class="text-text-muted max-w-xl mx-auto"&gt;Выберите формат работы&lt;/p&gt;&lt;/div&gt;
    &lt;div class="grid md:grid-cols-3 gap-8"&gt;
      &lt;article class="glass rounded-2xl p-8 hover:scale-105 transition-all duration-300"&gt;
        &lt;div class="text-center mb-6"&gt;&lt;div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-primary/10 mb-4"&gt;&lt;Icon name="lucide:coffee" class="w-7 h-7 text-primary"/&gt;&lt;/div&gt;&lt;h3 class="text-xl font-bold mb-2"&gt;Знакомство&lt;/h3&gt;&lt;p class="text-text-muted text-sm"&gt;Первичная консультация&lt;/p&gt;&lt;/div&gt;
        &lt;div class="text-center mb-6"&gt;&lt;span class="text-4xl font-bold"&gt;4 500 ₽&lt;/span&gt;&lt;/div&gt;
        &lt;ul class="space-y-3 mb-8"&gt;
          &lt;li class="flex items-start gap-3"&gt;&lt;Icon name="lucide:clock" class="w-5 h-5 text-primary flex-shrink-0 mt-0.5"/&gt;&lt;span class="text-text-muted"&gt;45 минут онлайн&lt;/span&gt;&lt;/li&gt;
          &lt;li class="flex items-start gap-3"&gt;&lt;Icon name="lucide:message-circle" class="w-5 h-5 text-primary flex-shrink-0 mt-0.5"/&gt;&lt;span class="text-text-muted"&gt;Погружение в ваш запрос&lt;/span&gt;&lt;/li&gt;
          &lt;li class="flex items-start gap-3"&gt;&lt;Icon name="lucide:map" class="w-5 h-5 text-primary flex-shrink-0 mt-0.5"/&gt;&lt;span class="text-text-muted"&gt;Определение точек роста&lt;/span&gt;&lt;/li&gt;
          &lt;li class="flex items-start gap-3"&gt;&lt;Icon name="lucide:clipboard-list" class="w-5 h-5 text-primary flex-shrink-0 mt-0.5"/&gt;&lt;span class="text-text-muted"&gt;Составление плана работы&lt;/span&gt;&lt;/li&gt;
        &lt;/ul&gt;
        &lt;a href="#contact" class="block w-full py-3 px-6 text-center rounded-xl border border-primary/50 hover:bg-primary/10 transition-all duration-300"&gt;Выбрать&lt;/a&gt;
      &lt;/article&gt;
      &lt;article class="relative glass rounded-2xl p-8 border-2 border-primary/50 hover:scale-105 transition-all duration-300 glow-primary"&gt;
        &lt;div class="absolute -top-4 left-1/2 -translate-x-1/2"&gt;&lt;span class="inline-flex items-center gap-1 px-4 py-1 bg-gradient-to-r from-primary to-secondary rounded-full text-sm font-semibold"&gt;&lt;Icon name="lucide:flame" class="w-4 h-4"/&gt;Выбор большинства&lt;/span&gt;&lt;/div&gt;
        &lt;div class="text-center mb-6 pt-4"&gt;&lt;div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-gradient-to-br from-primary/20 to-secondary/10 mb-4"&gt;&lt;Icon name="lucide:zap" class="w-7 h-7 text-primary"/&gt;&lt;/div&gt;&lt;h3 class="text-xl font-bold mb-2"&gt;Трансформация&lt;/h3&gt;&lt;p class="text-text-muted text-sm"&gt;Пакет из 4 сессий&lt;/p&gt;&lt;/div&gt;
        &lt;div class="text-center mb-6"&gt;&lt;span class="text-4xl font-bold gradient-text"&gt;21 600 ₽&lt;/span&gt;&lt;p class="text-sm text-text-muted mt-1"&gt;или 5 400 ₽ за сессию&lt;/p&gt;&lt;/div&gt;
        &lt;ul class="space-y-3 mb-8"&gt;
          &lt;li class="flex items-start gap-3"&gt;&lt;Icon name="lucide:check-circle" class="w-5 h-5 text-primary flex-shrink-0 mt-0.5"/&gt;&lt;span&gt;4 глубокие сессии&lt;/span&gt;&lt;/li&gt;
          &lt;li class="flex items-start gap-3"&gt;&lt;Icon name="lucide:repeat" class="w-5 h-5 text-primary flex-shrink-0 mt-0.5"/&gt;&lt;span&gt;Курс глубокой проработки&lt;/span&gt;&lt;/li&gt;
          &lt;li class="flex items-start gap-3"&gt;&lt;Icon name="lucide:shield-check" class="w-5 h-5 text-primary flex-shrink-0 mt-0.5"/&gt;&lt;span&gt;Системный подход&lt;/span&gt;&lt;/li&gt;
          &lt;li class="flex items-start gap-3"&gt;&lt;Icon name="lucide:trophy" class="w-5 h-5 text-accent flex-shrink-0 mt-0.5"/&gt;&lt;span class="font-medium"&gt;Устойчивый результат&lt;/span&gt;&lt;/li&gt;
        &lt;/ul&gt;
        &lt;a href="#contact" class="block w-full py-3 px-6 text-center rounded-xl bg-gradient-to-r from-primary to-secondary font-semibold hover:opacity-90 transition-all duration-300"&gt;Выбрать&lt;/a&gt;
      &lt;/article&gt;
      &lt;article class="glass rounded-2xl p-8 hover:scale-105 transition-all duration-300"&gt;
        &lt;div class="text-center mb-6"&gt;&lt;div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-secondary/10 mb-4"&gt;&lt;Icon name="lucide:user" class="w-7 h-7 text-secondary"/&gt;&lt;/div&gt;&lt;h3 class="text-xl font-bold mb-2"&gt;Глубокая работа&lt;/h3&gt;&lt;p class="text-text-muted text-sm"&gt;Сессия онлайн&lt;/p&gt;&lt;/div&gt;
        &lt;div class="text-center mb-6"&gt;&lt;span class="text-4xl font-bold"&gt;6 000 ₽&lt;/span&gt;&lt;/div&gt;
        &lt;ul class="space-y-3 mb-8"&gt;
          &lt;li class="flex items-start gap-3"&gt;&lt;Icon name="lucide:clock" class="w-5 h-5 text-secondary flex-shrink-0 mt-0.5"/&gt;&lt;span class="text-text-muted"&gt;60 минут онлайн&lt;/span&gt;&lt;/li&gt;
          &lt;li class="flex items-start gap-3"&gt;&lt;Icon name="lucide:search" class="w-5 h-5 text-secondary flex-shrink-0 mt-0.5"/&gt;&lt;span class="text-text-muted"&gt;Полноценная терапевтическая сессия&lt;/span&gt;&lt;/li&gt;
          &lt;li class="flex items-start gap-3"&gt;&lt;Icon name="lucide:message-square" class="w-5 h-5 text-secondary flex-shrink-0 mt-0.5"/&gt;&lt;span class="text-text-muted"&gt;Проработка конкретного вопроса&lt;/span&gt;&lt;/li&gt;
          &lt;li class="flex items-start gap-3"&gt;&lt;Icon name="lucide:wand-2" class="w-5 h-5 text-secondary flex-shrink-0 mt-0.5"/&gt;&lt;span class="text-text-muted"&gt;Коучинговый подход&lt;/span&gt;&lt;/li&gt;
        &lt;/ul&gt;
        &lt;a href="#contact" class="block w-full py-3 px-6 text-center rounded-xl border border-secondary/50 hover:bg-secondary/10 transition-all duration-300"&gt;Выбрать&lt;/a&gt;
      &lt;/article&gt;
    &lt;/div&gt;
  &lt;/div&gt;
&lt;/section&gt;
