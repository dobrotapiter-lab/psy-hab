---
import { Icon } from 'astro-icon/components';
---
&lt;footer id="contact" class="py-20 bg-bg-secondary relative overflow-hidden"&gt;
  &lt;div class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-20 bg-gradient-to-b from-primary/50 to-transparent"&gt;&lt;/div&gt;
  &lt;div class="max-w-4xl mx-auto px-6 relative z-10"&gt;
    &lt;div class="text-center mb-16"&gt;
      &lt;h2 class="text-3xl md:text-4xl font-bold mb-4"&gt;Остались вопросы? &lt;span class="gradient-text"&gt;Свяжитесь со мной&lt;/span&gt;&lt;/h2&gt;
      &lt;p class="text-text-muted max-w-xl mx-auto mb-8"&gt;Запись на консультацию через форму или мессенджеры&lt;/p&gt;
      &lt;div class="flex flex-wrap justify-center gap-4"&gt;
        &lt;a href="https://vk.com/evgeniypolienko" target="_blank" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl glass hover:bg-primary/10 transition-all"&gt;&lt;Icon name="simple-icons:vk" class="w-5 h-5"/&gt;&lt;span&gt;ВКонтакте&lt;/span&gt;&lt;/a&gt;
        &lt;a href="https://t.me/EvgeniyPolienko" target="_blank" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl glass hover:bg-primary/10 transition-all"&gt;&lt;Icon name="simple-icons:telegram" class="w-5 h-5"/&gt;&lt;span&gt;Telegram&lt;/span&gt;&lt;/a&gt;
        &lt;a href="tel:+79125543403" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl glass hover:bg-primary/10 transition-all"&gt;&lt;Icon name="lucide:phone" class="w-5 h-5"/&gt;&lt;span&gt;+7 (912) 554-34-03&lt;/span&gt;&lt;/a&gt;
      &lt;/div&gt;
    &lt;/div&gt;
    &lt;div class="glass rounded-2xl p-8 max-w-xl mx-auto mb-16"&gt;
      &lt;h3 class="text-xl font-bold mb-6 text-center"&gt;Записаться на консультацию&lt;/h3&gt;
      &lt;form class="space-y-4" id="contact-form"&gt;
        &lt;div&gt;&lt;label for="name" class="block text-sm text-text-muted mb-2"&gt;Ваше имя&lt;/label&gt;&lt;input type="text" id="name" name="name" required placeholder="Как к вам обращаться?" class="w-full px-4 py-3 rounded-xl bg-bg border border-border focus:border-primary outline-none transition-all"/&gt;&lt;/div&gt;
        &lt;div&gt;&lt;label for="phone" class="block text-sm text-text-muted mb-2"&gt;Телефон&lt;/label&gt;&lt;input type="tel" id="phone" name="phone" required placeholder="+7 (___) ___-__-__" class="w-full px-4 py-3 rounded-xl bg-bg border border-border focus:border-primary outline-none transition-all"/&gt;&lt;/div&gt;
        &lt;div&gt;&lt;label for="service" class="block text-sm text-text-muted mb-2"&gt;Услуга&lt;/label&gt;&lt;select id="service" name="service" required class="w-full px-4 py-3 rounded-xl bg-bg border border-border focus:border-primary outline-none transition-all"&gt;&lt;option value=""&gt;Выберите формат&lt;/option&gt;&lt;option value="intro"&gt;Первичная консультация (4 500 ₽)&lt;/option&gt;&lt;option value="single"&gt;Глубокая сессия (6 000 ₽)&lt;/option&gt;&lt;option value="package"&gt;Пакет из 4 сессий (21 600 ₽)&lt;/option&gt;&lt;/select&gt;&lt;/div&gt;
        &lt;div&gt;&lt;label for="message" class="block text-sm text-text-muted mb-2"&gt;Сообщение&lt;/label&gt;&lt;textarea id="message" name="message" rows="3" placeholder="Расскажите о вашем запросе..." class="w-full px-4 py-3 rounded-xl bg-bg border border-border focus:border-primary outline-none transition-all resize-none"&gt;&lt;/textarea&gt;&lt;/div&gt;
        &lt;button type="submit" class="w-full py-4 px-6 rounded-xl bg-gradient-to-r from-primary to-secondary font-semibold hover:opacity-90 transition-all flex items-center justify-center gap-2"&gt;&lt;Icon name="lucide:send" class="w-5 h-5"/&gt;Отправить заявку&lt;/button&gt;
        &lt;p class="text-xs text-text-muted text-center"&gt;Нажимая кнопку, вы соглашаетесь с политикой обработки персональных данных&lt;/p&gt;
      &lt;/form&gt;
      &lt;div id="success-message" class="hidden text-center py-8"&gt;
        &lt;div class="w-16 h-16 rounded-full bg-green-500/20 flex items-center justify-center mx-auto mb-4"&gt;&lt;Icon name="lucide:check" class="w-8 h-8 text-green-500"/&gt;&lt;/div&gt;
        &lt;h4 class="text-xl font-bold mb-2"&gt;Заявка отправлена!&lt;/h4&gt;
        &lt;p class="text-text-muted"&gt;Я свяжусь с вами в ближайшее время&lt;/p&gt;
      &lt;/div&gt;
    &lt;/div&gt;
    &lt;div class="flex flex-col md:flex-row items-center justify-between gap-4 pt-8 border-t border-border"&gt;
      &lt;div class="flex items-center gap-3"&gt;&lt;div class="w-10 h-10 rounded-full glass flex items-center justify-center"&gt;&lt;Icon name="lucide:sparkles" class="w-5 h-5 text-primary"/&gt;&lt;/div&gt;&lt;span class="font-semibold"&gt;Евгений Полиенко&lt;/span&gt;&lt;/div&gt;
      &lt;p class="text-text-muted text-sm"&gt;© 2026 Все права защищены&lt;/p&gt;
      &lt;div class="flex items-center gap-4"&gt;
        &lt;a href="https://vk.com/evgeniypolienko" target="_blank" class="w-10 h-10 rounded-full glass flex items-center justify-center hover:bg-primary/10 transition-all"&gt;&lt;Icon name="simple-icons:vk" class="w-5 h-5"/&gt;&lt;/a&gt;
        &lt;a href="https://t.me/EvgeniyPolienko" target="_blank" class="w-10 h-10 rounded-full glass flex items-center justify-center hover:bg-primary/10 transition-all"&gt;&lt;Icon name="simple-icons:telegram" class="w-5 h-5"/&gt;&lt;/a&gt;
      &lt;/div&gt;
    &lt;/div&gt;
  &lt;/div&gt;
&lt;/footer&gt;
&lt;script&gt;
  import QRCode from 'qrcode';
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMessage = document.getElementById('success-message');
  if (form) { form.addEventListener('submit', async (e) =&gt; { e.preventDefault(); await new Promise(r =&gt; setTimeout(r, 1000)); form.style.display = 'none'; successMessage?.classList.remove('hidden'); setTimeout(() =&gt; { form.reset(); form.style.display = 'block'; successMessage?.classList.add('hidden'); }, 5000); }); }
&lt;/script&gt;
